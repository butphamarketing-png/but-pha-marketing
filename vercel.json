{
  "version": 2,
  "buildCommand": "npm run build",
  "github": {
    "silent": true
  },
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/customer-renewals",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/domain-renewals",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/hosting-renewals",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/website-care-renewals",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/website-ads-renewals",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/facebook-ads-renewals",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/googlemaps-ads-renewals",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/tax-deadline-reminders",
      "schedule": "0 7 * * *"
    }
  ]
}
