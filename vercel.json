{
  "version": 2,
  "buildCommand": "npm run build",
  "github": {
    "silent": true
  },
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/customer-renewals",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/admin-renewal-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/tax-deadline-reminders",
      "schedule": "0 7 * * *"
    }
  ]
}
