# Phase 1 SaaS
DATABASE_URL="postgresql://user:password@host:5432/seo_saas?schema=public"
REDIS_URL="redis://localhost:6379"
OPENAI_API_KEY="sk-..."
AI_MOCK_MODE="true"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
API_PORT="4000"
SERP_API_KEY=""
SERPAPI_LOCATION="United States"
GSC_SITE_URL=""
GSC_ACCESS_TOKEN=""
GA4_PROPERTY_ID=""
GA4_ACCESS_TOKEN=""
SEO_CONTENT_BASE_PATH="/blog"
RANK_SCHEDULER_ENABLED="false"
RANK_SCHEDULER_INTERVAL_MS="86400000"

# Frontend -> backend
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# Existing marketing site variables
# Production: dùng một domain cố định (khuyến nghị https://www.butphamarketing.com) cho canonical, sitemap và schema.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Đổi Supabase: tạo project mới → chạy scripts/supabase-schema.sql → cập nhật 3 biến dưới
# Kiểm tra: npm run check:supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Postgres direct URI (Session mode) — bắt buộc cho /cms ERP (schema erp.*)
SUPABASE_DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
# Supabase: database (settings, blog, leads, media metadata…)
# Ảnh/file thực tế lưu trên Cloudflare R2 — URL public ghi vào Supabase (bảng media, settings…)
SUPABASE_STORAGE_BUCKET="media"

# Cloudflare R2 — bắt buộc cho upload ảnh (/api/media/upload)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="butpha-media"
R2_PUBLIC_BASE_URL="https://pub-xxxx.r2.dev"

ADMIN_EMAIL="butphamarketing@gmail.com"
ADMIN_PASSWORD="your-admin-password"
ADMIN_SESSION_SECRET="your-session-secret"

# Asset-Tracker ERP (/cms) — đăng nhập dùng chung ADMIN_EMAIL / ADMIN_PASSWORD (đổi trong /adminbp)
# Các API khác proxy tới CMS backend:
CMS_API_URL="http://localhost:8081"

# Customer renewal reminders (optional Zalo OA / webhook)
ZALO_OA_ACCESS_TOKEN=""
ZALO_OA_TEMPLATE_ID=""
ZALO_REMINDER_WEBHOOK_URL=""
CUSTOMER_RENEWAL_CRON_SECRET=""

# Domain expiry Gmail (cron /api/cron/domain-renewals — nhắc khi còn ≤ 30 ngày)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
